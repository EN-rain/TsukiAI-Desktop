# TsukiAI VoiceChat environment template (C# app side)
#
# IMPORTANT:
# - This file is a template only.
# - Copy to ".env" at project root if you want env-based overrides.
# - Discord bridge runtime keys (DISCORD_TOKEN, ASSEMBLYAI_API_KEY, etc.) are in:
#   discord-voice-bridge/.env
#
# Your current typical flow:
# Discord voice -> AssemblyAI STT (bridge) -> Remote LLM API (C#) -> Remote/Local TTS -> Discord playback

# ------------------------------
# Discord metadata (optional for C# side)
# ------------------------------
TSUKI_DISCORD_BOT_TOKEN=
TSUKI_DISCORD_GUILD_ID=
TSUKI_DISCORD_CHANNEL_ID=
# 0 = all users, max ulong (18446744073709551615) = auto focus
TSUKI_DISCORD_FOCUSED_USER_ID=18446744073709551615

# ------------------------------
# API keys (C# side)
# ------------------------------
TSUKI_ASSEMBLYAI_API_KEY=
TSUKI_DEEPL_API_KEY=
TSUKI_REMOTE_INFERENCE_API_KEY=

# ------------------------------
# Remote inference + TTS endpoints (C# side)
# ------------------------------
# Example provider URLs:
# - Cerebras: https://api.cerebras.ai/v1
# - Kimi:     https://api.moonshot.ai/v1
TSUKI_REMOTE_INFERENCE_URL=https://api.cerebras.ai/v1

# Remote VOICEVOX/ngrok URL example:
# TSUKI_CLOUD_TTS_URL=https://your-ngrok-subdomain.ngrok-free.dev
TSUKI_CLOUD_TTS_URL=

# ------------------------------
# Local VOICEVOX fallback
# ------------------------------
TSUKI_VOICEVOX_BASE_URL=http://127.0.0.1:50021

# ------------------------------
# Model + translation
# ------------------------------
# For provider mode this may be auto-normalized by settings/runtime.
TSUKI_MODEL_NAME=llama3.1-8b
TSUKI_USE_DEEPL_TRANSLATE=false
TSUKI_USE_DEEPL_FREE_API=true

# ------------------------------
# Voice runtime flags (must stay true for /api/voice/*)
# ------------------------------
TSUKI_VOICE_RUNTIME_V2=true
TSUKI_VOICE_API_CONTROLLER=true

# ------------------------------
# Semantic memory resilience (C# side)
# ------------------------------
# Enable long-lived Python worker process for semantic memory RPC.
TSUKI_SEMANTIC_PERSISTENT_WORKER=true
# Open local semantic-memory circuit after this many consecutive failures.
TSUKI_SEMANTIC_CB_FAILURES=5
# Circuit cooldown before half-open retry.
TSUKI_SEMANTIC_CB_COOLDOWN_MS=30000
# Per semantic request timeout.
TSUKI_SEMANTIC_REQUEST_TIMEOUT_MS=8000
