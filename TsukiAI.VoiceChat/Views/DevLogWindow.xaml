<Window x:Class="TsukiAI.VoiceChat.Views.DevLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Dev log"
        Icon="pack://application:,,,/tsuki_icon.jpg"
        Width="560"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        Foreground="#E8EAED"
        FontFamily="Segoe UI">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32"
                            CornerRadius="12"
                            GlassFrameThickness="0"
                            NonClientFrameEdges="None"
                            ResizeBorderThickness="10"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Color x:Key="BgDeep">#111318</Color>
        <Color x:Key="BgCard">#181B22</Color>
        <Color x:Key="BgInput">#1E222B</Color>
        <Color x:Key="Border">#2A2F3A</Color>
        <Color x:Key="TextPrimary">#E8EAED</Color>
        <Color x:Key="TextSecondary">#9AA0AC</Color>
        <Color x:Key="Accent">#7C6AEF</Color>

        <SolidColorBrush x:Key="BgDeepBrush" Color="{StaticResource BgDeep}"/>
        <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}"/>
        <SolidColorBrush x:Key="BgInputBrush" Color="{StaticResource BgInput}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>

        <Style x:Key="CaptionButton" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2F3A"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseCaptionButton" TargetType="{x:Type Button}" BasedOn="{StaticResource CaptionButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#C50F1F"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RoundedButton" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{StaticResource BgInputBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#252A35"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Margin="8"
                CornerRadius="12"
                Background="{StaticResource BgDeepBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.4" Color="Black"/>
            </Border.Effect>

            <Grid ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#1E222B"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="12,0"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                        shell:WindowChrome.IsHitTestVisibleInChrome="False">
                    <DockPanel LastChildFill="True" Background="Transparent">
                        <Button DockPanel.Dock="Right"
                                x:Name="CloseButton"
                                Style="{StaticResource CloseCaptionButton}"
                                Content="&#xE8BB;"
                                Click="CloseButton_Click"
                                ToolTip="Close"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button DockPanel.Dock="Right"
                                x:Name="CopyButton"
                                Style="{StaticResource CaptionButton}"
                                Content="&#xE8C8;"
                                Click="CopyButton_Click"
                                ToolTip="Copy log"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <TextBlock DockPanel.Dock="Left"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"
                                   Text="Dev log"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <Grid Grid.Row="1" Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource BgInputBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <TextBox x:Name="LogBox"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled"
                                 AcceptsReturn="True"
                                 FontFamily="Consolas, Segoe UI"
                                 FontSize="11"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="12"
                                 ScrollViewer.CanContentScroll="False"/>
                    </Border>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Style="{StaticResource RoundedButton}" Content="Clear" Click="Clear_Click" Margin="0,0,8,0" MinWidth="96"/>
                        <Button Style="{StaticResource RoundedButton}" Content="Refresh" Click="Refresh_Click" MinWidth="96"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
