<Window x:Class="TsukiAI.VoiceChat.Views.VoiceChatSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Voice Chat Settings"
        Icon="pack://application:,,,/tsuki_icon.jpg"
        Width="480"
        Height="620"
        MinWidth="440"
        MinHeight="520"
        Background="Transparent"
        FontFamily="Segoe UI"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      CornerRadius="12"
                      GlassFrameThickness="0"
                      NonClientFrameEdges="None"
                      ResizeBorderThickness="6"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <SolidColorBrush x:Key="BgPrimaryBrush" Color="#110E18"/>
        <SolidColorBrush x:Key="BgSecondaryBrush" Color="#171320"/>
        <SolidColorBrush x:Key="BgInputBrush" Color="#21192F"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3A3150"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E8EAED"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#B8AFCB"/>
        <SolidColorBrush x:Key="AccentBrushRes" Color="#9B7BFF"/>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#C4B5FD"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="FieldHint" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="Foreground" Value="#606060"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="SectionPanel" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,0,18"/>
        </Style>

        <Style x:Key="SettingsTextBox" TargetType="TextBox">
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Background" Value="{StaticResource BgInputBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsComboBox" TargetType="ComboBox">
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Background" Value="{StaticResource BgInputBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8"
                                                SnapsToDevicePixels="True">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0" Margin="10,7" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                                <Path Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0 Z" Fill="{StaticResource TextMutedBrush}"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="10,7"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              IsHitTestVisible="False"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}" MaxHeight="220">
                                    <Border Background="{StaticResource BgSecondaryBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Margin="0,4,0,0">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrushRes}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="{StaticResource BgInputBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource BgInputBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrushRes}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsButton" TargetType="Button">
            <Setter Property="Background" Value="#2A2D3A"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A3154"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,3,0,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="CheckBorder"
                                    Grid.Column="0"
                                    Width="18"
                                    Height="18"
                                    CornerRadius="4"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="2"
                                    Background="{StaticResource BgInputBrush}"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Top">
                                <Path x:Name="CheckMark"
                                      Data="M 0,4 L 3,7 L 8,0"
                                      Stroke="#FFFFFF"
                                      StrokeThickness="2"
                                      Stretch="Uniform"
                                      Margin="2"
                                      Opacity="0"/>
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              VerticalAlignment="Top"
                                              RecognizesAccessKey="True">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Opacity" Value="1"/>
                                <Setter TargetName="CheckBorder" Property="Background" Value="{StaticResource AccentBrushRes}"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource AccentBrushRes}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#6C5CE7"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="{StaticResource TextMutedBrush}"/>
                                <Setter TargetName="CheckMark" Property="Stroke" Value="{StaticResource TextMutedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgPrimaryBrush}" CornerRadius="12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1A1D2A" CornerRadius="12,12,0,0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" WindowChrome.IsHitTestVisibleInChrome="False">
                <Grid>
                    <TextBlock Text="Voice Chat Settings"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"
                               Margin="16,0"/>
                    <Button Content="✕"
                            Click="Close_Click"
                            Background="Transparent"
                            Foreground="#A0A0A0"
                            BorderThickness="0"
                            Width="32"
                            Height="32"
                            HorizontalAlignment="Right"
                            Margin="0,4,8,4"
                            WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="14,10,14,0">
                <StackPanel>
                    <StackPanel Style="{StaticResource SectionPanel}">
                            <TextBlock Style="{StaticResource SectionHeader}" Text="Voice Platform"/>
                            <TextBlock Style="{StaticResource FieldHint}"
                                       Text="Discord uses the Node bridge. VRChat voice uses your local microphone path and a virtual audio cable or routed output device."
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10"/>

                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Target Platform"/>
                                <ComboBox Style="{StaticResource SettingsComboBox}"
                                          SelectedIndex="{Binding VoicePlatformIndex, Mode=TwoWay}">
                                    <ComboBoxItem Content="Discord"/>
                                    <ComboBoxItem Content="VRChat"/>
                                    <ComboBoxItem Content="Other (No Integration)"/>
                                </ComboBox>
                            </StackPanel>
                    </StackPanel>

                    <StackPanel Style="{StaticResource SectionPanel}"
                                Visibility="{Binding IsDiscordPlatform, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Style="{StaticResource SectionHeader}" Text="Discord Voice Integration"/>
                            <TextBlock Style="{StaticResource FieldHint}"
                                       Text="Discord token / guild / channel IDs are handled from discord-voice-bridge/.env"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10"/>
                            <Button Style="{StaticResource SettingsButton}"
                                    Content="Open discord-voice-bridge/.env"
                                    HorizontalAlignment="Left"
                                    Padding="12,6"
                                    Margin="0,0,0,10"
                                    IsEnabled="{Binding IsDiscordPlatform}"
                                    Click="OpenDiscordEnv_Click"/>

                            <StackPanel>
                                <TextBlock Style="{StaticResource FieldLabel}" Text="STT Mode"/>
                                <TextBlock Style="{StaticResource FieldHint}" Text="Choose the speech-to-text provider used by the Discord bridge."/>
                                <ComboBox Style="{StaticResource SettingsComboBox}"
                                          IsEnabled="{Binding IsDiscordPlatform}"
                                          SelectedIndex="{Binding SttModeIndex, Mode=TwoWay}">
                                    <ComboBoxItem Content="AssemblyAI (Accurate, Slower)"/>
                                    <ComboBoxItem Content="Groq Whisper (Fast, Lower Latency)"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="STT Language"/>
                                <ComboBox Style="{StaticResource SettingsComboBox}"
                                          IsEnabled="{Binding IsDiscordPlatform}"
                                          SelectedValuePath="Tag"
                                          SelectedValue="{Binding SttLanguageCode, Mode=TwoWay}">
                                    <ComboBoxItem Content="Auto-detect" Tag="auto"/>
                                    <ComboBoxItem Content="English" Tag="en"/>
                                    <ComboBoxItem Content="Japanese" Tag="ja"/>
                                    <ComboBoxItem Content="Chinese" Tag="zh"/>
                                    <ComboBoxItem Content="Korean" Tag="ko"/>
                                    <ComboBoxItem Content="Spanish" Tag="es"/>
                                    <ComboBoxItem Content="French" Tag="fr"/>
                                    <ComboBoxItem Content="German" Tag="de"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Translation Strategy"/>
                                <ComboBox x:Name="CmbDiscordTranslationStrategy"
                                          Style="{StaticResource SettingsComboBox}"
                                          IsEnabled="{Binding IsDiscordPlatform}"
                                          SelectedIndex="{Binding DiscordTranslationStrategyIndex, Mode=TwoWay}">
                                    <ComboBoxItem Content="Translate Input to Japanese"/>
                                    <ComboBoxItem Content="Translate Response to Japanese"/>
                                    <ComboBoxItem Content="Bilingual - No Translation"/>
                                </ComboBox>
                            </StackPanel>
                    </StackPanel>

                    <StackPanel Style="{StaticResource SectionPanel}">
                            <TextBlock Style="{StaticResource SectionHeader}" Text="Voice Audio Devices"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Input Device"/>
                                    <ComboBox Style="{StaticResource SettingsComboBox}"
                                              ItemsSource="{Binding InputDevices}"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding VoiceChatInputDeviceNumber}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Output Device"/>
                                    <ComboBox Style="{StaticResource SettingsComboBox}"
                                              ItemsSource="{Binding OutputDevices}"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding VoiceChatOutputDeviceNumber}"/>
                                </StackPanel>
                            </Grid>
                    </StackPanel>

                    <StackPanel Style="{StaticResource SectionPanel}">
                            <TextBlock Style="{StaticResource SectionHeader}" Text="Local Microphone Input"/>
                            <TextBlock Style="{StaticResource FieldHint}"
                                       Text="For VRChat, keep this enabled and route Tsuki's output to a virtual microphone or cable device that VRChat listens to."
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10"/>
                            <StackPanel Margin="0,0,0,12">
                                <CheckBox x:Name="UseMicrophoneToggle"
                                          Style="{StaticResource SettingsCheckBox}"
                                          Content="Use Local Microphone (instead of Discord)"
                                          IsChecked="{Binding UseMicrophoneInput}"
                                          IsEnabled="{Binding IsDiscordPlatform}"
                                          Visibility="{Binding IsDiscordPlatform, Converter={StaticResource BoolToVisibilityConverter}}"
                                          Margin="0,0,0,8"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Microphone Device"/>
                                <ComboBox x:Name="CmbMicrophoneDevice"
                                          Style="{StaticResource SettingsComboBox}"
                                          SelectedIndex="0"
                                          IsEnabled="{Binding ElementName=UseMicrophoneToggle, Path=IsChecked}">
                                    <ComboBoxItem Content="Default Microphone"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,8">
                                <CheckBox x:Name="PushToTalkToggle"
                                          Style="{StaticResource SettingsCheckBox}"
                                          Content="Push-to-Talk Mode"
                                          IsChecked="{Binding MicrophonePushToTalk}"
                                          IsEnabled="{Binding ElementName=UseMicrophoneToggle, Path=IsChecked}"
                                          Margin="0,0,0,4"/>
                            </StackPanel>

                            <Button x:Name="BtnTestMicrophone"
                                    Click="TestMicrophone_Click"
                                    Style="{StaticResource SettingsButton}"
                                    Content="Test Microphone"
                                    MinHeight="36"
                                    Padding="12,0"
                                    IsEnabled="{Binding ElementName=UseMicrophoneToggle, Path=IsChecked}"
                                    Margin="0,4,0,0"/>

                            <StackPanel Margin="0,12,0,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Voice Reception Toggle Hotkey"/>
                                <TextBox Style="{StaticResource SettingsTextBox}"
                                         Text="{Binding VoiceReceptionToggleKeyText, Mode=TwoWay}"/>
                            </StackPanel>
                    </StackPanel>

                    <StackPanel Style="{StaticResource SectionPanel}"
                                Visibility="{Binding IsVrChatPlatform, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Style="{StaticResource SectionHeader}" Text="VRChat Voice Options"/>

                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="STT Mode"/>
                                <TextBlock Style="{StaticResource FieldHint}" Text="Speech-to-text provider for your microphone input."/>
                                <ComboBox Style="{StaticResource SettingsComboBox}"
                                          SelectedIndex="{Binding SttModeIndex, Mode=TwoWay}">
                                    <ComboBoxItem Content="AssemblyAI (Accurate, Slower)"/>
                                    <ComboBoxItem Content="Groq Whisper (Fast, Lower Latency)"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="STT Language"/>
                                <ComboBox Style="{StaticResource SettingsComboBox}"
                                          SelectedValuePath="Tag"
                                          SelectedValue="{Binding SttLanguageCode, Mode=TwoWay}">
                                    <ComboBoxItem Content="Auto-detect" Tag="auto"/>
                                    <ComboBoxItem Content="English" Tag="en"/>
                                    <ComboBoxItem Content="Japanese" Tag="ja"/>
                                    <ComboBoxItem Content="Chinese" Tag="zh"/>
                                    <ComboBoxItem Content="Korean" Tag="ko"/>
                                    <ComboBoxItem Content="Spanish" Tag="es"/>
                                    <ComboBoxItem Content="French" Tag="fr"/>
                                    <ComboBoxItem Content="German" Tag="de"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Translation Strategy"/>
                                <ComboBox Style="{StaticResource SettingsComboBox}"
                                          SelectedIndex="{Binding DiscordTranslationStrategyIndex, Mode=TwoWay}">
                                    <ComboBoxItem Content="Translate Input to Japanese"/>
                                    <ComboBoxItem Content="Translate Response to Japanese"/>
                                    <ComboBoxItem Content="Bilingual - No Translation"/>
                                </ComboBox>
                            </StackPanel>
                    </StackPanel>

                    <StackPanel Style="{StaticResource SectionPanel}"
                                Visibility="{Binding IsOtherPlatform, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Style="{StaticResource SectionHeader}" Text="Standalone Voice Options"/>
                            <TextBlock Style="{StaticResource FieldHint}"
                                       Text="Tsuki listens on the selected input device and plays TTS to the output device. Route your mic and game audio through VoiceMeeter to control what Tsuki hears."
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10"/>

                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="STT Mode"/>
                                <TextBlock Style="{StaticResource FieldHint}" Text="Speech-to-text provider for microphone input."/>
                                <ComboBox Style="{StaticResource SettingsComboBox}"
                                          SelectedIndex="{Binding SttModeIndex, Mode=TwoWay}">
                                    <ComboBoxItem Content="AssemblyAI (Accurate, Slower)"/>
                                    <ComboBoxItem Content="Groq Whisper (Fast, Lower Latency)"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="STT Language"/>
                                <ComboBox Style="{StaticResource SettingsComboBox}"
                                          SelectedValuePath="Tag"
                                          SelectedValue="{Binding SttLanguageCode, Mode=TwoWay}">
                                    <ComboBoxItem Content="Auto-detect" Tag="auto"/>
                                    <ComboBoxItem Content="English" Tag="en"/>
                                    <ComboBoxItem Content="Japanese" Tag="ja"/>
                                    <ComboBoxItem Content="Chinese" Tag="zh"/>
                                    <ComboBoxItem Content="Korean" Tag="ko"/>
                                    <ComboBoxItem Content="Spanish" Tag="es"/>
                                    <ComboBoxItem Content="French" Tag="fr"/>
                                    <ComboBoxItem Content="German" Tag="de"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Translation Strategy"/>
                                <ComboBox Style="{StaticResource SettingsComboBox}"
                                          SelectedIndex="{Binding DiscordTranslationStrategyIndex, Mode=TwoWay}">
                                    <ComboBoxItem Content="Translate Input to Japanese"/>
                                    <ComboBoxItem Content="Translate Response to Japanese"/>
                                    <ComboBoxItem Content="Bilingual - No Translation"/>
                                </ComboBox>
                            </StackPanel>
                    </StackPanel>

                    <StackPanel Style="{StaticResource SectionPanel}"
                                Visibility="{Binding IsVrChatPlatform, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Style="{StaticResource SectionHeader}" Text="VRChat Routing"/>
                            <TextBlock Style="{StaticResource FieldHint}"
                                       Text="VRChat does not expose direct voice-bot injection. The practical setup is: your mic into Tsuki, Tsuki TTS to a virtual audio output, and VRChat listening to that routed device."
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,10"/>

                            <StackPanel Margin="0,0,0,8">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="OSC Host"/>
                                <TextBox Style="{StaticResource SettingsTextBox}"
                                         Text="{Binding VrChatOscHost, Mode=TwoWay}"
                                         IsEnabled="{Binding IsVrChatPlatform}"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="VRChat Inbound Port"/>
                                    <TextBox Style="{StaticResource SettingsTextBox}"
                                             Text="{Binding VrChatOscInputPortText, Mode=TwoWay}"
                                             IsEnabled="{Binding IsVrChatPlatform}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="VRChat Outbound Port"/>
                                    <TextBox Style="{StaticResource SettingsTextBox}"
                                             Text="{Binding VrChatOscOutputPortText, Mode=TwoWay}"
                                             IsEnabled="{Binding IsVrChatPlatform}"/>
                                </StackPanel>
                            </Grid>

                            <CheckBox Style="{StaticResource SettingsCheckBox}"
                                      Content="Enable VRChat chatbox fallback for text responses later"
                                      IsChecked="{Binding VrChatUseChatboxFallback}"
                                      IsEnabled="{Binding IsVrChatPlatform}"/>
                    </StackPanel>

                    <StackPanel Style="{StaticResource SectionPanel}">
                            <TextBlock Style="{StaticResource SectionHeader}" Text="Voice Chat History"/>
                            <Button Click="ClearVoiceChatHistory_Click"
                                    Style="{StaticResource SettingsButton}"
                                    HorizontalAlignment="Left"
                                    Content="Clear voice chat history"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,14,10">
                <Button Width="100" Margin="0,0,10,0" Click="Close_Click"
                        Style="{StaticResource SettingsButton}"
                        Content="Close"/>
                <Button Width="100" Click="Save_Click"
                        Style="{StaticResource SettingsButton}"
                        Background="{StaticResource AccentBrushRes}"
                        Foreground="White"
                        BorderThickness="0"
                        Content="Save"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
