<Window x:Class="TsukiAI.VoiceChat.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="TsukiAI"
        Icon="pack://application:,,,/tsuki_icon.jpg"
        Width="900"
        Height="650"
        MinWidth="700"
        MinHeight="500"
        Background="Transparent"
        FontFamily="Segoe UI"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            CornerRadius="12"
                            GlassFrameThickness="0"
                            NonClientFrameEdges="None"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="BgMainBrush" Color="#171320"/>
        <SolidColorBrush x:Key="BgCardBrush" Color="#110E18"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3A3150"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E8EAED"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B8AFCB"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2F2740"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#171320"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CaptionButton" TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        </Style>

        <Style x:Key="CloseCaptionButton" TargetType="Button" BasedOn="{StaticResource CaptionButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#C50F1F"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#2F2740"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A3154"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#171320"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernRadioButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="RadioBorder"
                                    Grid.Column="0"
                                    Width="18"
                                    Height="18"
                                    CornerRadius="9"
                                    BorderBrush="#4A3E66"
                                    BorderThickness="2"
                                    Background="#110E18"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center">
                                <Ellipse x:Name="RadioDot" Width="8" Height="8" Fill="#9B7BFF" Opacity="0"/>
                            </Border>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RadioDot" Property="Opacity" Value="1"/>
                                <Setter TargetName="RadioBorder" Property="BorderBrush" Value="#9B7BFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RadioBorder" Property="BorderBrush" Value="#7A5FE0"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernToggleSwitch" TargetType="ToggleButton">
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#2F2740"/>
            <Setter Property="BorderBrush" Value="#4A3E66"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track"
                                    Background="#2F2740"
                                    BorderBrush="#4A3E66"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="13">
                            </Border>
                            <Border x:Name="Thumb"
                                    Width="20"
                                    Height="20"
                                    CornerRadius="10"
                                    Background="#E8EAED"
                                    HorizontalAlignment="Left"
                                    Margin="3,0,0,0"
                                    VerticalAlignment="Center">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTransform" X="0"/>
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#9B7BFF"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="#9B7BFF"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="26"
                                                             Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="0"
                                                             Duration="0:0:0.18">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="#7A5FE0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="8"
            CornerRadius="12"
            Background="{StaticResource BgMainBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <Grid shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="{StaticResource BgCardBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" shell:WindowChrome.IsHitTestVisibleInChrome="False">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="🌙" FontSize="16" Margin="0,0,8,0"/>
                    <TextBlock Text="TsukiAI" FontSize="14" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,8,0">
                    <Button Content="Dev Logs" Style="{StaticResource TitleBarButton}" Click="DevLogs_Click" Width="Auto" Padding="8,0" FontSize="12" Margin="4,0" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button Content="Settings" Style="{StaticResource TitleBarButton}" Click="OpenMainSettings_Click" Width="Auto" Padding="8,0" FontSize="12" Margin="4,0" shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button Style="{StaticResource CaptionButton}" Click="Minimize_Click" Margin="4,0" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Viewbox Width="16" Height="16">
                            <Path Data="M 3 8 L 13 8"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.9"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Viewbox>
                    </Button>
                    <Button x:Name="MaximizeButton" Style="{StaticResource CaptionButton}" Click="Maximize_Click" Margin="4,0" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Viewbox Width="16" Height="16">
                            <Path Data="M 3 3 L 13 3 L 13 13 L 3 13 Z"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.7"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"/>
                        </Viewbox>
                    </Button>
                    <Button x:Name="RestoreButton" Style="{StaticResource CaptionButton}" Click="Maximize_Click" Visibility="Collapsed" Margin="4,0" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Viewbox Width="16" Height="16">
                            <Path Data="M 5 5 L 11 5 L 11 11 L 5 11 Z M 7 3 L 13 3 L 13 9"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.7"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"/>
                        </Viewbox>
                    </Button>
                    <Button Style="{StaticResource CloseCaptionButton}" Click="Close_Click" Margin="4,0" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Viewbox Width="16" Height="16">
                            <Path Data="M 4 4 L 12 12 M 12 4 L 4 12"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.9"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"/>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" Background="{StaticResource BgCardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,1">
                <StackPanel Margin="0,10,0,8">
                    <TextBlock x:Name="VoiceChatTitleText"
                               Text="🎤 Voice Chat"
                               HorizontalAlignment="Center"
                               Foreground="#FFFFFF"
                               FontWeight="SemiBold"
                               FontSize="16"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="2" Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="2"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="LeftSidebarPanel"
                        Grid.Column="0"
                        Width="300"
                        Background="#1A1525"
                        CornerRadius="12"
                        BorderBrush="#2D2540"
                        BorderThickness="1"
                        Padding="0"
                        Margin="0,0,8,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.3" Color="#000000"/>
                    </Border.Effect>
                    <Grid>
                        <Grid x:Name="SidebarExpandedContent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" 
                                    Background="#231D33" 
                                    CornerRadius="12,12,0,0"
                                    BorderBrush="#2D2540"
                                    BorderThickness="0,0,0,1"
                                    Padding="16,14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Path Grid.Column="0"
                                          Width="18" Height="18"
                                          Stretch="Uniform"
                                          Fill="#9B7BFF"
                                          Data="M 12,2 C 11.4,2 11,2.4 11,3 L 11,6 C 11,6.6 11.4,7 12,7 C 12.6,7 13,6.6 13,6 L 13,3 C 13,2.4 12.6,2 12,2 M 17,5 C 16.7,4.6 16.2,4.5 15.8,4.7 L 13.2,6 C 12.8,6.2 12.6,6.7 12.8,7.1 C 13,7.5 13.5,7.7 13.9,7.5 L 16.5,6.2 C 16.9,6 17,5.5 17,5 M 7,5 C 7,5.5 7.3,6 7.7,6.2 L 10.3,7.5 C 10.7,7.7 11.2,7.5 11.4,7.1 C 11.6,6.7 11.4,6.2 11,6 L 8.4,4.7 C 8,4.5 7.5,4.6 7,5 M 12,8 C 9.2,8 7,10.2 7,13 C 7,15.8 9.2,18 12,18 C 14.8,18 17,15.8 17,13 C 17,10.2 14.8,8 12,8 M 19.5,10 C 19,9.8 18.5,10 18.3,10.4 L 17,13 C 16.8,13.4 17,13.9 17.4,14.1 C 17.8,14.3 18.3,14.1 18.5,13.7 L 19.8,11.1 C 20,10.7 19.9,10.2 19.5,10 M 4.5,10 C 4.1,10.2 4,10.7 4.2,11.1 L 5.5,13.7 C 5.7,14.1 6.2,14.3 6.6,14.1 C 7,13.9 7.2,13.4 7,13 L 5.7,10.4 C 5.5,10 5,9.8 4.5,10"/>
                                    <TextBlock Grid.Column="1"
                                               Text="Voice Controls"
                                               Foreground="#FFFFFF"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="10,0,0,0"/>
                                    <Button x:Name="ToggleSidebarButton"
                                            Grid.Column="2"
                                            Width="28"
                                            Height="28"
                                            Style="{StaticResource TitleBarButton}"
                                            ToolTip="Collapse sidebar"
                                            Click="ToggleSidebarButton_Click">
                                        <Path Width="14" Height="14"
                                              Stretch="Uniform"
                                              Fill="#A69BC4"
                                              Data="M 11,4 L 5,12 L 11,20 M 19,4 L 13,12 L 19,20"/>
                                    </Button>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" 
                                    Background="#201A2E" 
                                    BorderBrush="#2D2540"
                                    BorderThickness="0,0,0,1"
                                    Padding="16,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Path Grid.Column="0"
                                          Width="16" Height="16"
                                          Stretch="Uniform"
                                          Fill="#7DD3C0"
                                          Data="M 12,2 C 6.5,2 2,6.5 2,12 C 2,17.5 6.5,22 12,22 C 17.5,22 22,17.5 22,12 C 22,6.5 17.5,2 12,2 M 12,4 C 16.4,4 20,7.6 20,12 C 20,16.4 16.4,20 12,20 C 7.6,20 4,16.4 4,12 C 4,7.6 7.6,4 12,4 M 12,6 C 11.4,6 11,6.4 11,7 L 11,12.2 C 11,12.6 11.2,13 11.6,13.2 L 15.6,15.4 C 16.1,15.7 16.7,15.5 17,15 C 17.3,14.5 17.1,13.9 16.6,13.6 L 13,11.6 L 13,7 C 13,6.4 12.6,6 12,6"/>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Text="Voice Reception"
                                                   Foreground="#FFFFFF"
                                                   FontSize="13"
                                                   FontWeight="Medium"/>
                                        <TextBlock Text="Listen and respond"
                                                   Foreground="#8B8099"
                                                   FontSize="10"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="VoiceReceptionToggle"
                                                  Grid.Column="2"
                                                  IsChecked="True"
                                                  Style="{StaticResource ModernToggleSwitch}"/>
                                </Grid>
                            </Border>

                            <ScrollViewer Grid.Row="2" 
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="16">
                                <StackPanel x:Name="SidebarContentPanel">
                                    <Border Background="#231D33" 
                                            CornerRadius="10" 
                                            BorderBrush="#2D2540"
                                            BorderThickness="1"
                                            Padding="14"
                                            Margin="0,0,0,12"
                                            Visibility="Collapsed">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid Grid.Column="0" Width="32" Height="32" VerticalAlignment="Center">
                                                <Ellipse Width="32" Height="32" Fill="#2D2540"/>
                                                <Path Width="16" Height="16"
                                                      Stretch="Uniform"
                                                      Fill="#9B7BFF"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Data="M 4,4 L 4,20 L 20,20 L 20,6 L 12,6 L 12,4 L 4,4 M 6,8 L 18,8 L 18,18 L 6,18 L 6,8 M 8,10 L 8,12 L 16,12 L 16,10 L 8,10"/>
                                            </Grid>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="Voice Bridge"
                                                           Foreground="#FFFFFF"
                                                           FontSize="12"
                                                           FontWeight="Medium"/>
                                                <TextBlock x:Name="ServerStatusText"
                                                           Text="Stopped"
                                                           Foreground="#E74C3C"
                                                           FontSize="11"/>
                                            </StackPanel>
                                            <ToggleButton x:Name="ServerStatusToggle"
                                                          Grid.Column="2"
                                                          VerticalAlignment="Center"
                                                          Style="{StaticResource ModernToggleSwitch}"
                                                          Checked="ServerStatusToggle_Checked"
                                                          Unchecked="ServerStatusToggle_Unchecked"/>
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="FOCUS MODE" 
                                               FontSize="10" 
                                               FontWeight="Bold"
                                               Foreground="#6B5F7D"
                                               Margin="4,16,0,10"/>
                                    
                                    <Border Background="#231D33" 
                                            CornerRadius="10" 
                                            BorderBrush="#2D2540"
                                            BorderThickness="1"
                                            Padding="4">
                                        <StackPanel>
                                            <RadioButton x:Name="AllUsersFocusRadio" 
                                                         Content="All Users" 
                                                         Style="{StaticResource ModernRadioButton}" 
                                                         Margin="10,8,10,4" 
                                                         Checked="AllUsersFocus_Checked"/>
                                            <Border Background="#2D2540" Height="1" Margin="10,0"/>
                                            <RadioButton x:Name="AutoFocusRadio" 
                                                         Content="Auto Focus" 
                                                         Style="{StaticResource ModernRadioButton}" 
                                                         IsChecked="True" 
                                                         Margin="10,4" 
                                                         Checked="AutoFocus_Checked"/>
                                            <Border Background="#2D2540" Height="1" Margin="10,0"/>
                                            <RadioButton x:Name="SpecificUserFocusRadio" 
                                                         Content="Specific User" 
                                                         Style="{StaticResource ModernRadioButton}" 
                                                         Margin="10,4,10,8" 
                                                         Checked="SpecificUserFocus_Checked"/>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="SpecificUserPanel" 
                                            Background="#231D33" 
                                            CornerRadius="10" 
                                            BorderBrush="#2D2540"
                                            BorderThickness="1"
                                            Padding="12"
                                            Margin="0,10,0,0"
                                            Visibility="Collapsed">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0"
                                                       Text="User ID"
                                                       Foreground="#8B8099"
                                                       FontSize="11"
                                                       Margin="0,0,0,6"/>
                                            <Grid Grid.Row="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="FocusedUserIdInput"
                                                         Grid.Column="0"
                                                         Background="#110E18"
                                                         Foreground="{StaticResource TextPrimaryBrush}"
                                                         BorderBrush="#3A3150"
                                                         BorderThickness="1"
                                                         Padding="10,8"
                                                         FontSize="12"
                                                         Text=""/>
                                                <Button Grid.Column="2"
                                                        Content="Apply"
                                                        Style="{StaticResource ModernButton}"
                                                        Padding="14,8"
                                                        FontSize="12"
                                                        Click="ApplyFocusedUser_Click"/>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <Border x:Name="FocusStatusPanel" 
                                            Background="#231D33" 
                                            CornerRadius="10" 
                                            BorderBrush="#2D2540"
                                            BorderThickness="1"
                                            Padding="14"
                                            Margin="0,12,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" 
                                                    Width="8" 
                                                    Height="8" 
                                                    CornerRadius="4" 
                                                    Background="#9B7BFF"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,10,0">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.6" Color="#9B7BFF"/>
                                                </Border.Effect>
                                            </Border>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock x:Name="FocusStatusTitle" 
                                                           Text="Auto Focus Mode" 
                                                           FontSize="12" 
                                                           FontWeight="Medium"
                                                           Foreground="#FFFFFF" 
                                                           Margin="0,0,0,2"/>
                                                <TextBlock x:Name="FocusStatusDescription" 
                                                           Text="Automatically detects and focuses on the speaking user"
                                                           FontSize="10"
                                                           Foreground="#8B8099"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border x:Name="VrChatRoutePanel" 
                                            Background="Transparent" 
                                            CornerRadius="10" 
                                            BorderBrush="#9B7BFF"
                                            BorderThickness="1"
                                            Padding="14"
                                            Margin="0,12,0,0"
                                            Visibility="Collapsed">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Path Grid.Column="0"
                                                  Width="20" Height="20"
                                                  Stretch="Uniform"
                                                  Fill="#9B7BFF"
                                                  VerticalAlignment="Top"
                                                  Margin="0,2,10,0"
                                                  Data="M 12,2 C 6.5,2 2,6.5 2,12 C 2,17.5 6.5,22 12,22 C 17.5,22 22,17.5 22,12 C 22,6.5 17.5,2 12,2 M 12,4 C 16.4,4 20,7.6 20,12 C 20,16.4 16.4,20 12,20 C 7.6,20 4,16.4 4,12 C 4,7.6 7.6,4 12,4 M 12,6 C 11.4,6 11,6.4 11,7 L 11,12.2 C 11,12.6 11.2,13 11.6,13.2 L 15.6,15.4 C 16.1,15.7 16.7,15.5 17,15 C 17.3,14.5 17.1,13.9 16.6,13.6 L 13,11.6 L 13,7 C 13,6.4 12.6,6 12,6"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="VRChat Routing"
                                                           FontSize="12"
                                                           FontWeight="Medium"
                                                           Foreground="#9B7BFF"
                                                           Margin="0,0,0,6"/>
                                                <TextBlock x:Name="VrChatRouteDescription"
                                                           Text="Set output to virtual cable, configure VRChat to listen on that input. OSC: 127.0.0.1:9000-9001"
                                                           FontSize="10"
                                                           Foreground="#A69BC4"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Background="#1E1929" 
                                            CornerRadius="8" 
                                            Padding="12"
                                            Margin="0,16,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Path Grid.Column="0"
                                                  Width="14" Height="14"
                                                  Stretch="Uniform"
                                                  Fill="#6B5F7D"
                                                  VerticalAlignment="Top"
                                                  Margin="0,1,8,0"
                                                  Data="M 11,7 L 11,13 L 13,13 L 13,7 L 11,7 M 12,2 C 6.5,2 2,6.5 2,12 C 2,17.5 6.5,22 12,22 C 17.5,22 22,17.5 22,12 C 22,6.5 17.5,2 12,2 M 12,20 C 7.6,20 4,16.4 4,12 C 4,7.6 7.6,4 12,4 C 16.4,4 20,7.6 20,12 C 20,16.4 16.4,20 12,20 M 11,15 L 11,17 L 13,17 L 13,15 L 11,15"/>
                                            <TextBlock x:Name="PlatformTipText"
                                                       Grid.Column="1"
                                                       Text="Right-click user in Discord and select Copy ID to focus on a specific user"
                                                       FontSize="10"
                                                       Foreground="#6B5F7D"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <Grid x:Name="SidebarCollapsedContent" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Button x:Name="ToggleSidebarButtonCollapsed"
                                    Grid.Row="0"
                                    Width="36"
                                    Height="36"
                                    Margin="6,12,6,0"
                                    Style="{StaticResource TitleBarButton}"
                                    ToolTip="Expand sidebar"
                                    Click="ToggleSidebarButton_Click">
                                <Path Width="16" Height="16"
                                      Stretch="Uniform"
                                      Fill="#A69BC4"
                                      Data="M 13,4 L 19,12 L 13,20 M 5,4 L 11,12 L 5,20"/>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Margin="0,0,0,8"
                                    Visibility="{Binding IsSpeechIndicatorVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="{Binding SpeechIndicatorText, Mode=OneWay}"
                                       Foreground="#C4B5FD"
                                       FontSize="11"
                                       Margin="2,0,0,4"/>
                            <ProgressBar IsIndeterminate="True"
                                         Height="3"
                                         Background="#241C36"
                                         Foreground="#9B7BFF"
                                         BorderThickness="0"/>
                        </StackPanel>

                        <Border Grid.Row="1" Background="{StaticResource BgCardBrush}" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <TextBox x:Name="ActivityFeedBox"
                                     Margin="10"
                                     Text="{Binding ActivityFeedText, Mode=OneWay}"
                                     IsReadOnly="True"
                                     IsReadOnlyCaretVisible="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"
                                     TextChanged="ActivityFeedBox_TextChanged"/>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{StaticResource BgCardBrush}" CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12">
                            <Grid>
                                <TextBox x:Name="TtsTestInput"
                                         Text="Type text to test TTS..."
                                         Background="Transparent"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         CaretBrush="#FFFFFF"
                                         SelectionBrush="#7C6AEF"
                                         BorderThickness="0"
                                         FontSize="13"
                                         MaxLength="1000"
                                         TextChanged="TtsTestInput_TextChanged"
                                         GotFocus="TtsTestInput_GotFocus"
                                         LostFocus="TtsTestInput_LostFocus"/>
                                <TextBlock x:Name="TtsCharCounter" Text="0 / 1000"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Bottom"
                                           Foreground="#606060"
                                           FontSize="10"/>
                            </Grid>
                        </Border>

                        <Button Grid.Column="2" x:Name="PlayHereButton" Content="Play Here" Style="{StaticResource ModernButton}" Background="#3498DB" Foreground="White" Padding="24,10" FontWeight="SemiBold" Click="TtsTestPlayHere_Click"/>
                        <Button Grid.Column="4" x:Name="PlatformPlaybackButton" Content="Play in Discord" Style="{StaticResource ModernButton}" Background="#27AE60" Foreground="White" Padding="24,10" FontWeight="SemiBold" Click="TtsTestPlayInDiscord_Click"/>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
